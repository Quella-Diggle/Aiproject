{
  "name": "stickynotes",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop sticky notes with structured events (Electron + Vue 3)",
  "main": "out/main/index.js",
  "author": "StickyNotes Team",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --x64 --config.win.signAndEditExecutable=false",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-bold": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@tiptap/vue-3": "^2.10.3",
    "auto-launch": "^5.0.6",
    "naive-ui": "^2.40.4",
    "nanoid": "^5.0.9",
    "pinia": "^2.3.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vue-tsc": "^2.2.0"
  }
}
